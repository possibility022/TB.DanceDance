<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:access="clr-namespace:TB.DanceDance.Mobile.Pages.Access"
             x:DataType="access:GetAccessPageModel"
             x:Name="GetAccessPageView"
             x:Class="TB.DanceDance.Mobile.Pages.Access.GetAccessPage">
    <ContentPage.Content>
        <StackLayout Margin="10, 0, 10, 0">
            <RefreshView IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding RefreshCommand}">
                <ScrollView VerticalOptions="Fill">
                    <StackLayout
                        BindableLayout.ItemsSource="{Binding Accesses}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="access:AccessModel">
                                <Border Padding="10" Margin="0,10,0,0">
                                    <VerticalStackLayout>
                                        <HorizontalStackLayout Spacing="10">
                                            <Label Text="{Binding TypeAsFriendlyString}"/>
                                            <Label Text="{Binding Season}"/>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout>
                                            <CheckBox IsEnabled="{Binding CanBeRequested}"
                                                  IsChecked="{Binding IsRequesting, Mode=TwoWay}"
                                                  ></CheckBox>
                                            <Label Padding="0,3,0,0" Text="{Binding Name}" FontSize="24"/>
                                        </HorizontalStackLayout>
                                        <Label Text="Oczekuje na zatwierdzenie"
                                               IsVisible="{Binding IsPending}"
                                               TextColor="{StaticResource Magenta}"
                                        />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </StackLayout>
                </ScrollView>
            </RefreshView>
            <Button Text="Uzyskaj Dostęp" Command="{Binding RequestAccessCommand}"></Button>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>