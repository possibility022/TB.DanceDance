<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:TB.DanceDance.Mobile.Pages.Controls"
             xmlns:models="clr-namespace:TB.DanceDance.Mobile.Library.Data.Models;assembly=TB.DanceDance.Mobile.Library"
             xmlns:events="clr-namespace:TB.DanceDance.Mobile.Pages.Events"
             x:DataType="events:EventsPageModel"
             x:Name="EventsPageView"
             x:Class="TB.DanceDance.Mobile.Pages.Events.EventsPage">
    <Grid>
        <StackLayout Margin="10">
            <RefreshView IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding RefreshCommand}">
                <ScrollView Margin="0,10,0,0">
                    <StackLayout
                        BindableLayout.ItemsSource="{Binding UserEvents}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:Event">
                                <Border Padding="10" Margin="0,10,0,0">
                                    <VerticalStackLayout>
                                        <Label Text="{Binding Name}" FontSize="24">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding NavigateToEventDetailsCommand, Source={RelativeSource AncestorType={x:Type events:EventsPageModel}}, x:DataType=events:EventsPageModel}"
                                                    CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </StackLayout>
                </ScrollView>
            </RefreshView>
        </StackLayout>
        <VerticalStackLayout HorizontalOptions="End" VerticalOptions="End">
            <controls:AddEventButton Command="{Binding NavigateToAddEventCommand}"></controls:AddEventButton>
        </VerticalStackLayout>
    </Grid>
</ContentPage>