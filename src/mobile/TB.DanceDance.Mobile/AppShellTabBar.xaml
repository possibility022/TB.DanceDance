<?xml version="1.0" encoding="utf-8" ?>

<Grid xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
      xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
      xmlns:local="clr-namespace:TB.DanceDance.Mobile"
      SafeAreaEdges="None"
      x:Class="TB.DanceDance.Mobile.AppShellTabBar">

    <!-- Flat bottom tab bar mirroring the web navbar's active/inactive treatment:
         light bar, teal (is-primary) active icon, grey inactive icon. -->
    <Border SafeAreaEdges="Container"
            StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource OffBlack}}"
            Shadow="{Shadow Radius=4, Offset='0,-1', Opacity=0.12}">
        <Grid x:Name="Buttons"
              ColumnDefinitions="*,*,*,*"
              SafeAreaEdges="None"
              Padding="20,4">
            <Grid.Resources>
                <Style TargetType="ImageButton">
                    <Setter Property="Padding" Value="12"/>
                    <Setter Property="HeightRequest" Value="48"/>
                    <Setter Property="BackgroundColor" Value="Transparent"/>
                </Style>
            </Grid.Resources>
            <!-- Wydarzenia (event) -->
            <ImageButton Grid.Column="0" Clicked="IconClicked">
                <ImageButton.Source>
                    <FontImageSource Glyph="&#xe878;" FontFamily="MaterialRound" Size="24"
                                     Color="{StaticResource Gray500}"/>
                </ImageButton.Source>
            </ImageButton>
            <!-- Lekcje Reg. (group) -->
            <ImageButton Grid.Column="1" Clicked="IconClicked">
                <ImageButton.Source>
                    <FontImageSource Glyph="&#xe7ef;" FontFamily="MaterialRound" Size="24"
                                     Color="{StaticResource Gray500}"/>
                </ImageButton.Source>
            </ImageButton>
            <!-- Osobiste (video_library) -->
            <ImageButton Grid.Column="2" Clicked="IconClicked">
                <ImageButton.Source>
                    <FontImageSource Glyph="&#xe04a;" FontFamily="MaterialRound" Size="24"
                                     Color="{StaticResource Gray500}"/>
                </ImageButton.Source>
            </ImageButton>
            <!-- Konto (account_circle) -->
            <ImageButton Grid.Column="3" Clicked="IconClicked">
                <ImageButton.Source>
                    <FontImageSource Glyph="&#xe853;" FontFamily="MaterialRound" Size="24"
                                     Color="{StaticResource Gray500}"/>
                </ImageButton.Source>
            </ImageButton>
        </Grid>
    </Border>
</Grid>
