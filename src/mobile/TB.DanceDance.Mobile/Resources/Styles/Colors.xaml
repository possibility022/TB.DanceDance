<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sys="clr-namespace:System;assembly=netstandard">

    <!-- Palette aligned with the web app's Bulma 1.0.4 defaults (no project overrides).
         Values derived from bulma/sass/utilities/initial-variables.scss + derived-variables.scss.
         Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <!-- Bulma $primary = $turquoise = hsl(171,100%,41%) -->
    <Color x:Key="Primary">#00D1B2</Color>
    <!-- lightened teal for dark-theme surfaces / legibility -->
    <Color x:Key="PrimaryDark">#19E0C6</Color>
    <!-- Bulma $text = $grey-dark = hsl(221,14%,29%), used as text on light controls -->
    <Color x:Key="PrimaryDarkText">#404654</Color>
    <!-- light teal tint -->
    <Color x:Key="Secondary">#CFF6EF</Color>
    <Color x:Key="SecondaryDarkText">#19E0C6</Color>
    <!-- Bulma $link = $blue = hsl(233,100%,63%) -->
    <Color x:Key="Tertiary">#4258FF</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <!-- accent text colour: remapped to Bulma $link -->
    <Color x:Key="Magenta">#4258FF</Color>
    <!-- strong heading text: Bulma $black-ter hsl(221,14%,14%) -->
    <Color x:Key="MidnightBlue">#1F2229</Color>
    <!-- dark-theme page background: Bulma $black-bis hsl(221,14%,9%) -->
    <Color x:Key="OffBlack">#14161A</Color>

    <!-- Gray ramp regenerated from Bulma's scheme ramp hsl(221,14%,L) -->
    <Color x:Key="Gray100">#EBECF0</Color>
    <Color x:Key="Gray200">#D6D9E0</Color>
    <Color x:Key="Gray300">#ABB1BF</Color>
    <Color x:Key="Gray400">#8B94A7</Color>
    <Color x:Key="Gray500">#69748C</Color>
    <Color x:Key="Gray600">#535C6E</Color>
    <Color x:Key="Gray900">#2E333D</Color>
    <Color x:Key="Gray950">#1F2229</Color>

    <!-- Page / surface backgrounds: Bulma $white-ter hsl(221,14%,96%) -->
    <Color x:Key="BackgroundLight">#F3F4F6</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

    <!-- Corner-radius tokens mirroring Bulma's $radius-* (rem -> px at 16px base) -->
    <sys:Double x:Key="RadiusSmall">4</sys:Double>
    <sys:Double x:Key="RadiusBase">6</sys:Double>
    <sys:Double x:Key="RadiusLarge">12</sys:Double>
    <sys:Double x:Key="RadiusRounded">9999</sys:Double>
</ResourceDictionary>
