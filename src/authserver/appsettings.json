{
  "ConnectionStrings": {
    "AuthDbConnectionString": ""
  },
  "AuthServer": {
    "Issuer": "https://localhost:7259/",
    "AllowedCorsOrigins": [
      "http://localhost:3000",
      "http://localhost:4200",
      "http://localhost:5112"
    ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.OpenTelemetry" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "File", "Args": { "path": "Logs/log.txt" } },
      { "Name": "OpenTelemetry", "Args": { "includeScopes": true } }
    ]
  }
}
