{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "File", "Args": { "path": "Logs/danceDanceConverter.log.txt", "rollingInterval": "Day" } },
      { "Name": "OpenTelemetry", "Args": { "includeScopes": true } }
    ]
  },
  "ConverterConfig": {
    "FFMPGDefaultFolder": "D:\\ffmpeg\\ffmpeg-2026-03-15-git-6ba0b59d8b-essentials_build",
    "ApiOrigin": "https://localhost:7068/",
    "OAuthOrigin": "https://localhost:7259/",
    "WorkDir": "mediafolder",
    "DelayInMinutes": 5,
    "TokenProviderOptions": {
      "ClientId": "tbdancedanceconverter",
      "ClientSecret": "other",
      "Scope": "tbdancedanceapi.convert"
    }
  }
}
